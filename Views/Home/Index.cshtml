@model List<Game>
@{
    ViewData["Title"] = "Início | Esportify";
}

@section Styles {
    <style>
        :root {
            --black: #0a0a0a;
            --dark-grey: #1a1a1a;
            --medium-grey: #2a2a2a;
            --light-grey: #3a3a3a;
            --green: #00ff88;
            --dark-green: #00cc6a;
            --text: #ffffff;
            --error: #ff4655;
        }

        body {
            background-color: var(--black);
            color: var(--text);
            font-family: 'Inter', sans-serif;
        }

        .homepage-container {
            padding: 2rem 0;
        }

        /* Sidebar Styles */
        .sidebar {
            position: sticky;
            top: 2rem;
            height: fit-content;
        }

        .sidebar-card {
            background: var(--dark-grey);
            border: 1px solid var(--medium-grey);
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }

        .sidebar-title {
            color: var(--green);
            font-size: 1.25rem;
            font-weight: 700;
            margin: 0;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .btn-outline-success {
            border: 2px solid var(--green);
            color: var(--green);
            font-size: 0.8rem;
            font-weight: 600;
            padding: 0.4rem 1rem;
            border-radius: 8px;
            transition: all 0.3s ease;
        }

        .btn-outline-success:hover {
            background-color: var(--green);
            border-color: var(--green);
            color: var(--black);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(0, 255, 136, 0.3);
        }

        /* Sidebar-specific button styling */
        .sidebar .btn-outline-success {
            border: 1px solid var(--green);
            font-size: 0.8rem;
            padding: 0.4rem 0.8rem;
            border-radius: 6px;
            transition: all 0.2s ease;
            width: 100%;
            margin-bottom: 1rem;
        }

        .sidebar .btn-outline-success:hover {
            background-color: var(--green);
            border-color: var(--green);
            color: var(--black);
            transform: translateY(-1px);
            box-shadow: none;
        }

        .favorite-games-list {
            margin: 1rem 0 0 0;
            padding: 0;
        }

        .favorite-game-item {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.5rem;
            margin-bottom: 0.5rem;
            border-radius: 8px;
            background: var(--medium-grey);
            border: 1px solid var(--light-grey);
            transition: all 0.2s ease;
            cursor: pointer;
            text-decoration: none;
            color: inherit;
        }

        .favorite-game-item:hover {
            background: var(--light-grey);
            border-color: var(--green);
            transform: translateX(4px);
            color: inherit;
        }

        .game-icon {
            width: 32px;
            height: 32px;
            border-radius: 6px;
            object-fit: cover;
            flex-shrink: 0;
        }

        .game-name {
            font-size: 0.9rem;
            font-weight: 500;
            color: var(--text);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .more-games {
            padding: 0.5rem;
            text-align: center;
            background: var(--dark-grey);
            border-radius: 8px;
            border: 1px dashed var(--green);
            margin-top: 0.5rem;
        }

        .more-games-text {
            color: var(--green);
            font-size: 0.85rem;
            font-weight: 600;
        }

        .empty-state {
            text-align: center;
            padding: 2rem 1rem;
            color: var(--text);
        }

        .empty-state i {
            font-size: 2rem;
            margin-bottom: 1rem;
            color: var(--green);
            opacity: 0.7;
        }

        .empty-state p {
            margin-bottom: 1.5rem;
            opacity: 0.8;
            font-size: 0.95rem;
        }

        /* Sidebar-specific empty state */
        .sidebar .empty-state {
            padding: 1.5rem 0.5rem;
        }

        .sidebar .empty-state i {
            font-size: 1.5rem;
            margin-bottom: 0.75rem;
        }

        .sidebar .empty-state p {
            font-size: 0.85rem;
            margin-bottom: 1rem;
        }

        .btn-success {
            background: var(--green);
            border: none;
            color: var(--black);
            font-weight: 700;
            padding: 0.75rem 2rem;
            border-radius: 8px;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
        }

            .btn-success:hover {
                background: var(--dark-green);
                transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(0, 255, 136, 0.3);
            }

        .more-games-count {
            grid-column: 1 / -1;
            text-align: center;
            margin-top: 1rem;
        }

            .more-games-count small {
                color: var(--green);
                font-weight: 600;
                font-size: 0.9rem;
            }

        /* Main Content Styles */
        .main-content {
            padding-left: 2rem;
        }

        .section-title {
            color: var(--green);
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 0;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* Game Cards Grid */
        .games-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 1.5rem;
            margin-top: 1.5rem;
        }

        .game-card {
            position: relative;
            border-radius: 12px;
            overflow: hidden;
            aspect-ratio: 1/1;
            border: 2px solid var(--medium-grey);
            transition: all 0.3s ease;
        }

            .game-card:hover {
                border-color: var(--green);
                transform: translateY(-8px);
                box-shadow: 0 12px 32px rgba(0, 255, 136, 0.25);
            }

        .game-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.3s ease;
        }

        .game-card:hover .game-image {
            transform: scale(1.1);
        }

        .game-overlay {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            background: linear-gradient(transparent, rgba(0, 0, 0, 0.95));
            padding: 1.5rem;
            color: var(--text);
        }

        .game-title {
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            color: var(--text);
        }

        .game-tournaments {
            font-size: 0.9rem;
            color: var(--green);
            font-weight: 600;
        }

        /* Tournament Cards */
        .tournaments-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
            margin-top: 1.5rem;
        }

        .tournament-card {
            background: var(--dark-grey);
            border: 2px solid var(--medium-grey);
            border-radius: 12px;
            overflow: hidden;
            transition: all 0.3s ease;
        }

            .tournament-card:hover {
                border-color: var(--green);
                transform: translateY(-4px);
                box-shadow: 0 8px 24px rgba(0, 255, 136, 0.2);
            }

        .tournament-image {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .tournament-content {
            padding: 1.5rem;
        }

        .tournament-title {
            font-size: 1.3rem;
            font-weight: 700;
            margin-bottom: 1rem;
            color: var(--text);
        }

        .tournament-meta {
            display: flex;
            gap: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .meta-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.9rem;
            color: var(--text);
        }

            .meta-item i {
                color: var(--green);
            }

        .prize-badge {
            background: var(--green);
            color: var(--black);
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-weight: 700;
            font-size: 0.9rem;
            display: inline-block;
            margin-bottom: 1rem;
        }

        /* CTA Section */
        .cta-section {
            background: linear-gradient(135deg, var(--dark-grey) 0%, var(--medium-grey) 100%);
            border: 2px solid var(--green);
            border-radius: 16px;
            padding: 3rem;
            margin: 3rem 0;
            text-align: center;
        }

        .cta-title {
            color: var(--green);
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 1rem;
            text-transform: uppercase;
        }

        .cta-text {
            font-size: 1.2rem;
            margin-bottom: 2rem;
            opacity: 0.9;
        }

        .cta-btn {
            background: var(--green);
            color: var(--black);
            border: none;
            padding: 1rem 3rem;
            font-size: 1.1rem;
            font-weight: 700;
            border-radius: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
        }

            .cta-btn:hover {
                background: var(--dark-green);
                transform: translateY(-3px);
                box-shadow: 0 12px 32px rgba(0, 255, 136, 0.3);
            }

        .main-content {
            padding-left: 0;
        }

        .games-grid {
            grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
            gap: 1rem;
        }

        .tournaments-grid {
            grid-template-columns: 1fr;
        }

        .cta-section {
            padding: 2rem;
        }

        .cta-title {
            font-size: 2rem;
        }

        .games-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .tournament-meta {
            flex-direction: column;
            gap: 0.5rem;
        }
        
        /* Additional Styles */
        .game-tag {
            background: var(--medium-grey);
            color: var(--green);
            padding: 0.25rem 0.75rem;
            border-radius: 15px;
            font-size: 0.8rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .create-team-cta {
            background: linear-gradient(135deg, var(--dark-grey) 0%, var(--medium-grey) 100%);
            border: 2px solid var(--green);
            border-radius: 16px;
            padding: 2.5rem;
        }
        
        .create-team-cta h2 {
            color: var(--green);
            font-weight: 700;
            margin-bottom: 0.5rem;
        }
        
        .create-team-cta p {
            color: var(--text);
            opacity: 0.9;
            margin-bottom: 0;
        }
</style>
}

<div class="homepage-container">
    <div class="row">
        <!-- Barra Lateral Esquerda - Jogos Favoritos -->
    <div class="col-lg-3 col-xl-2 sidebar">
        <div class="sidebar-card">
            <h3 class="sidebar-title">Os Meus Jogos</h3>
            <a asp-controller="Games" asp-action="Index" class="btn btn-sm btn-outline-success">Adicionar Mais</a>

            @if (User.Identity.IsAuthenticated && ViewData["FavoriteGames"] is List<Game> favoriteGames && favoriteGames.Any())
            {
                <div class="favorite-games-list">
                    @foreach (var game in favoriteGames.Take(8))
                    {
                        <a asp-controller="Games" asp-action="Details" asp-route-id="@game.Id" class="favorite-game-item">
                            <img src="@game.ImageUrl" alt="@game.Name" class="game-icon"
                                 onerror="this.onerror=null;this.src='/images/games/default.jpg';">
                            <span class="game-name">@game.Name</span>
                        </a>
                    }
                    @if (favoriteGames.Count > 8)
                    {
                        <div class="more-games">
                            <span class="more-games-text">+@(favoriteGames.Count - 8) mais jogos</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="fas fa-gamepad"></i>
                    <p>Ainda sem jogos favoritos</p>
                    <a asp-controller="Games" asp-action="Index" class="btn btn-success">Explorar Jogos</a>
                </div>
            }
        </div>
    </div>

        <!-- Conteúdo Principal -->
        <div class="col-lg-9 col-xl-10 main-content">
            <!-- Secção de Torneios Futuros -->
            <section class="mb-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="section-title">Torneios Futuros</h2>
                    <a asp-controller="Tournaments" asp-action="Index" class="btn btn-sm btn-outline-success">Ver Todos</a>
                </div>

                <div class="tournaments-grid">
                    @if (ViewData["UpcomingTournaments"] is List<Tournament> upcomingTournaments && upcomingTournaments.Any())
                    {
                        @foreach (var tournament in upcomingTournaments)
                        {
                            <div class="tournament-card">
                                <img src="@tournament.ImageUrl" alt="@tournament.Name" class="tournament-image"
                                     onerror="this.onerror=null;this.src='/images/tournaments/default.png';">
                                <div class="tournament-content">
                                    <div class="prize-badge">@tournament.PrizePool.ToString("C")</div>
                                    <h3 class="tournament-title">@tournament.Name</h3>
                                    <div class="tournament-meta">
                                        <div class="meta-item">
                                            <i class="fas fa-gamepad"></i>
                                            <span>@(tournament.Game?.Name ?? "Game not found")</span>
                                        </div>
                                        <div class="meta-item">
                                            <i class="fas fa-calendar-alt"></i>
                                            <span>@tournament.StartDate.ToString("dd/MM/yyyy")</span>
                                        </div>
                                        <div class="meta-item">
                                            <i class="fas fa-users"></i>
                                            <span>@(tournament.Registrations?.Count ?? 0)/@tournament.MaxTeams equipas</span>
                                        </div>
                                    </div>
                                    <a asp-controller="Tournaments" asp-action="Details" asp-route-id="@tournament.Id" class="btn btn-success w-100">Ver Detalhes</a>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-trophy"></i>
                            <p>Nenhum torneio programado para os próximos 7 dias</p>
                            <a asp-controller="Tournaments" asp-action="Index" class="btn btn-success">Explorar Torneios</a>
                        </div>
                    }
                </div>
            </section>

            <!-- Secção de Torneios Populares -->
            <section class="mb-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="section-title">Torneios Populares</h2>
                    <a asp-controller="Tournaments" asp-action="Index" class="btn btn-sm btn-outline-success">Ver Todos</a>
                </div>

                <div class="row">
                    @if (ViewData["PopularTournaments"] is List<Tournament> popularTournaments && popularTournaments.Any())
                    {
                        @foreach (var tournament in popularTournaments)
                        {
                            <div class="col-md-6 mb-4">
                                <div class="tournament-card">
                                    <img src="@tournament.ImageUrl" alt="@tournament.Name" class="tournament-image"
                                         onerror="this.onerror=null;this.src='/images/tournaments/default.png';">
                                    <div class="tournament-content">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <span class="badge bg-success">@(tournament.Game?.Name ?? "Game not found")</span>
                                            <span class="prize-badge">@tournament.PrizePool.ToString("C")</span>
                                        </div>
                                        <h3 class="tournament-title">@tournament.Name</h3>
                                        <div class="tournament-meta mb-3">
                                            <div class="meta-item">
                                                <i class="fas fa-calendar-alt"></i>
                                                <span>Início: @tournament.StartDate.ToString("dd/MM/yyyy")</span>
                                            </div>
                                            <div class="meta-item">
                                                <i class="fas fa-users"></i>
                                                <span>@(tournament.Registrations?.Count ?? 0) equipas inscritas</span>
                                            </div>
                                            <div class="meta-item">
                                                <i class="fas fa-clock"></i>
                                                <span>Prazo: @tournament.RegistrationDeadline.ToString("dd/MM/yyyy")</span>
                                            </div>
                                        </div>
                                        <a asp-controller="Tournaments" asp-action="Details" asp-route-id="@tournament.Id" class="btn btn-success w-100">Participar</a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12">
                            <div class="empty-state">
                                <i class="fas fa-trophy"></i>
                                <p>Nenhum torneio popular encontrado</p>
                                <a asp-controller="Tournaments" asp-action="Index" class="btn btn-success">Explorar Torneios</a>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <!-- Secção de Explorar Jogos -->
            <section class="mb-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="section-title">Explorar Jogos</h2>
                    <a asp-controller="Games" asp-action="Index" class="btn btn-sm btn-outline-success">Ver Todos</a>
                </div>

                <div class="row">
                    @if (ViewData["PopularGames"] is List<Game> popularGames)
                    {
                        @foreach (var game in popularGames)
                        {
                            <div class="col-6 col-md-3 mb-4">
                                <div class="game-card">
                                    <a asp-controller="Games" asp-action="Details" asp-route-id="@game.Id">
                                        <img src="@game.ImageUrl" alt="@game.Name" class="game-image">
                                        <div class="game-overlay">
                                            <h3 class="game-title">@game.Name</h3>
                                            <span class="game-tournaments">@game.Tournaments.Count torneios</span>
                                        </div>
                                    </a>
                                </div>
                            </div>
                        }
                    }
                </div>
            </section>

            <!-- Chamada à Ação para Criar Equipa -->
            @if (User.Identity.IsAuthenticated)
            {
                <section class="mb-5">
                    <div class="create-team-cta">
                        <div class="row align-items-center">
                            <div class="col-md-8">
                                <h2>Pronto para criar a tua equipa de sonho?</h2>
                                <p>Cria ou junta-te a uma equipa para competir em torneios juntos</p>
                            </div>
                            <div class="col-md-4 text-md-end">
                                <a asp-controller="Teams" asp-action="Create" class="btn btn-success btn-lg">Criar Equipa</a>
                            </div>
                        </div>
                    </div>
                </section>
            }

            <!-- Torneios com Grandes Prémios -->
            <section class="mb-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="section-title">Torneios com Grandes Prémios</h2>
                    <a asp-controller="Tournaments" asp-action="Index" class="btn btn-sm btn-outline-success">Ver Todos</a>
                </div>

                <div class="row">
                    @if (ViewData["HighPrizeTournaments"] is IEnumerable<Tournament> highPrizeTournaments && highPrizeTournaments.Any())
                    {
                        @foreach (var tournament in highPrizeTournaments)
                        {
                            <div class="col-md-4 mb-4">
                                <div class="tournament-card">
                                    <img src="@tournament.ImageUrl" alt="@tournament.Name" class="tournament-image"
                                         onerror="this.onerror=null;this.src='/images/tournaments/default.png';">
                                    <div class="tournament-content">
                                        <div class="prize-badge">@tournament.PrizePool.ToString("C")</div>
                                        <span class="badge bg-secondary mb-2">@(tournament.Game?.Name ?? "Game not found")</span>
                                        <h3 class="tournament-title">@tournament.Name</h3>
                                        <div class="tournament-meta mb-3">
                                            <div class="meta-item">
                                                <i class="fas fa-calendar-alt"></i>
                                                <span>@tournament.StartDate.ToString("dd/MM/yyyy")</span>
                                            </div>
                                            <div class="meta-item">
                                                <i class="fas fa-users"></i>
                                                <span>@(tournament.Registrations?.Count ?? 0)/@tournament.MaxTeams equipas</span>
                                            </div>
                                            <div class="meta-item">
                                                <i class="fas fa-trophy"></i>
                                                <span>@tournament.PrizePool.ToString("C") em prémios</span>
                                            </div>
                                        </div>
                                        <a asp-controller="Tournaments" asp-action="Details" asp-route-id="@tournament.Id" class="btn btn-success w-100">Ver Detalhes</a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12">
                            <div class="empty-state">
                                <i class="fas fa-trophy"></i>
                                <p>Nenhum torneio com grandes prémios disponível no momento</p>
                                <a asp-controller="Tournaments" asp-action="Index" class="btn btn-success">Explorar Torneios</a>
                            </div>
                        </div>
                    }
                </div>
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.opacity = 1;
                        entry.target.style.transform = 'translateY(0)';
                    }
                });
            }, { threshold: 0.1 });

            document.querySelectorAll('.tournament-card, .game-card, .popular-tournament-card, .prize-tournament-card').forEach(card => {
                card.style.opacity = 0;
                card.style.transform = 'translateY(20px)';
                card.style.transition = 'opacity 0.5s, transform 0.5s';
                observer.observe(card);
            });
        });
    </script>
}